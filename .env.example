# Copy to .env.local and fill in from your Supabase project (Settings → API).
# Only the anon key goes here — it's fine to ship in the browser bundle as long as
# the RLS policy in supabase/knowledge_cards.sql (read-only) is applied. The
# service_role key (used by the bot/Hermes Agent skill to write cards) must NEVER
# go in this file or anywhere in the frontend — it belongs only on the bot's machine.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (optional) — reminders that fire with the tab CLOSED.
# Only the PUBLIC key belongs here. The private key goes to Supabase secrets, never the browser:
#   supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=mailto:you@example.com
# Generate a fresh pair with:
#   node -e "const{generateKeyPairSync}=require('crypto');const{publicKey,privateKey}=generateKeyPairSync('ec',{namedCurve:'prime256v1'});console.log('pub',Buffer.from(publicKey.export({type:'spki',format:'der'}).subarray(-65)).toString('base64url'));console.log('priv',privateKey.export({format:'jwk'}).d)"
VITE_VAPID_PUBLIC_KEY=
